# ─── EKT Training — environment configuration ───────────────────────
# Copy this file to ".env" and change the values before deploying.

# Port the server listens on
PORT=3000

# Initial admin password (optional).
# On first start the server seeds the admin account (elijah02.ek@gmail.com).
# If this variable is set, it is used as that account's password. If it is
# left empty, a random temporary password is generated and printed ONCE to
# the console, and must be changed on first login.
ADMIN_INITIAL_PASSWORD=

# Secret used to sign session cookies. Use a long random string.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=please-change-this-to-a-long-random-string

# Set to "true" only when served over HTTPS (enables the Secure cookie flag)
SECURE_COOKIES=false

# ─── Email (contact form via Resend) ────────────────────────────────
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=

# The "from" address. It MUST be on a domain you have verified in Resend.
# Before your domain is verified you can use the sandbox sender below, which
# can only deliver to your own Resend account email:
#   CONTACT_FROM=EKT Training <onboarding@resend.dev>
CONTACT_FROM=EKT Training <onboarding@resend.dev>

# Where contact-form submissions are delivered (the site owner's inbox)
CONTACT_TO=sgivvin@gmail.com

# ─── Stripe (monthly membership billing) ────────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
# NEVER commit real keys — this .env file is gitignored on purpose.
# The SECRET key must stay server-side only. The publishable key (pk_...)
# is safe to expose but isn't needed here (we use hosted Stripe Checkout).
STRIPE_SECRET_KEY=

# The recurring (monthly) Price to subscribe members to. Create a Product
# with a monthly recurring price in the Stripe dashboard, then paste its
# price id (starts with "price_") here.
STRIPE_PRICE_ID=

# Webhook signing secret (starts with "whsec_"). Create an endpoint at
# https://dashboard.stripe.com/webhooks pointing to  <your-domain>/api/stripe/webhook
# and subscribe to: checkout.session.completed, customer.subscription.created,
# customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=

# Public base URL of the deployed site (used for Stripe redirect URLs)
PUBLIC_BASE_URL=http://localhost:3000

# ─── Booking availability ───────────────────────────────────────────
# Timezone label shown to clients on the booking calendar.
BUSINESS_TZ=America/New_York

# Optional: override the weekly availability template. JSON keyed by weekday
# (0=Sun … 6=Sat), each an array of 24h "HH:mm" start times. If unset, a
# sensible default (weekday mornings/evenings + Saturday mornings) is used.
# Example: {"1":["06:00","18:00"],"6":["09:00","10:00"]}
AVAILABILITY_JSON=
